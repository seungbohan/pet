# [SECURITY] 이 파일을 복사하여 .env로 사용하세요.
# .env 파일은 절대 Git에 커밋하지 마세요 (.gitignore에 이미 포함됨)

# JWT 시크릿 키 (최소 32자 이상, 랜덤 생성 권장)
# 생성 예시: openssl rand -base64 64
JWT_SECRET=

# 데이터베이스 (로컬 개발용)
DB_USERNAME=
DB_PASSWORD=

# 공공데이터 API 키
PET_API_KEY=

# 프론트엔드 URL
FRONTEND_URL=http://localhost:5173

# 프로덕션 Docker 배포용 (docker-compose.yml에서 사용)
DB_ROOT_PASSWORD=
DB_USER=withpet
DB_PASSWORD=
